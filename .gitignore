# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Cython build artifacts (the .pyx is the source of truth)
src/corridors/_engine.c
src/corridors/_engine.html
*.pyd
*.so

# Virtual envs
.venv/
venv/
env/

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Editors / OS
.idea/
.vscode/
.DS_Store

# Corridors runtime state. The az_benchmarks/ directory is intentionally
# tracked: benchmark history is keyed by stable hardware fingerprints (one
# file per fingerprint, so pods never merge-conflict), giving a fresh pod of
# a known hardware class its tuned self-play defaults without
# re-benchmarking. az_benchmarks.json is the legacy machine-local monolith.
corridors.json
az_benchmarks.json
corridors_tt.sqlite3
corridors_tt.sqlite3-journal
corridors_tt.sqlite3-wal
corridors_tt.sqlite3-shm

# NN artifacts. Datasets are machine-local except for datasets explicitly moved
# into nn_data/shared/ from Dataset Manager.
nn_data/*
!nn_data/shared/
!nn_data/shared/**
nn_data/shared/**/.dataset-index.json
nn_data/shared/**/*.tmp
nn_data/shared/**/*.bak

# Checkpoints are machine-local except for manually curated models copied into
# nn_checkpoints/best/ from the checkpoint-management menu.
nn_checkpoints/*
!nn_checkpoints/best/
!nn_checkpoints/best/**

# Claude Code local settings
.claude/settings.local.json
